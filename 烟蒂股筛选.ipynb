   "cell_type": "markdown",
   "source": [
    "---\n",
    "\n",
    "### 鍒嗘瀽鏁版嵁鐨勭粨鏋刓n",
    "\n",
    "渚嬪 鍒嗘瀽璐㈡姤鐨勫悇涓鐩殑id鐨勫垎鏁ｆ儏鍐? 渚嬪鍜岃涓氱殑鍏崇郴, "
   ],
   "id": "6654f5497b9e22a1"
  },
  {
   "metadata": {},
   "cell_type": "markdown",
   "source": "#### 绠€鍗曡緭鍑哄叕鍙哥殑鎽樿",
   "id": "fae611956195b045"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-02-23T06:52:23.594501Z",
     "start_time": "2026-02-23T06:52:23.498986Z"
    }
   },
   "cell_type": "code",
   "source": [
    "import pandas as pd\n",
    "from typing import Iterable, Optional, Any, Dict\n",
    "\n",
    "\n",
    "def build_company_overview_df(storage, tickers: Optional[Iterable[str]] = None) -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    鐢熸垚鈥滃叕鍙稿熀鏈俊鎭寮鸿〃鈥濓紙涓€琛屼竴涓猼icker锛夛紝鏁版嵁鏉ユ簮锛歕n",
    "      - company_profile\n",
    "      - security_profile\n",
    "      - financial_indicator_snapshot\n",
    "\n",
    "    杈撳嚭鍒楋紙鎸変綘鐨勮姹傦級锛歕n",
    "      ticker, 鍚嶇О, 娉ㄥ唽鍦? 鎴愮珛鏃ユ湡, 琛屼笟, 鍛樺伐浜烘暟, 鍏徃浠嬬粛, 娓偂閫? 甯傚€?娓厓), 鑲℃伅鐜嘥TM(%), PE, PB\n",
    "    \"\"\"\n",
    "    if tickers is None:\n",
    "        tickers = storage.list_tickers()\n",
    "\n",
    "    def _first_value(df: Optional[pd.DataFrame], candidates: Iterable[str]) -> Any:\n",
    "        if df is None or not isinstance(df, pd.DataFrame) or df.empty:\n",
    "            return None\n",
    "        for c in candidates:\n",
    "            if c in df.columns:\n",
    "                v = df.iloc[0][c]\n",
    "                if pd.isna(v):\n",
    "                    return None\n",
    "                return v\n",
    "        return None\n",
    "\n",
    "    def _as_bool(v: Any) -> Optional[bool]:\n",
    "        if v is None or (isinstance(v, float) and pd.isna(v)):\n",
    "            return None\n",
    "        if isinstance(v, bool):\n",
    "            return v\n",
    "        s = str(v).strip().lower()\n",
    "        if s in {\"鏄痋", \"y\", \"yes\", \"true\", \"1\"}:\n",
    "            return True\n",
    "        if s in {\"鍚", \"n\", \"no\", \"false\", \"0\"}:\n",
    "            return False\n",
    "        return None\n",
    "\n",
    "    rows = []\n",
    "    for t in tickers:\n",
    "        try:\n",
    "            b = storage.load_bundle(t)\n",
    "        except Exception:\n",
    "            # 璇讳笉鍒癰undle灏辫烦杩囷紙涔熷彲鏀规垚璁板綍閿欒琛岋級\n",
    "            continue\n",
    "\n",
    "        cp = b.data.get(\"company_profile\")\n",
    "        sp = b.data.get(\"security_profile\")\n",
    "        fi = b.data.get(\"financial_indicator_snapshot\")\n",
    "\n",
    "        name = _first_value(cp, [\"鍏徃鍚嶇О\", \"鍚嶇О\"]) or _first_value(sp, [\"璇佸埜绠€绉癨", \"绠€绉癨", \"name\"])\n",
    "        reg_place = _first_value(cp, [\"娉ㄥ唽鍦癨"])\n",
    "        founded = _first_value(cp, [\"鍏徃鎴愮珛鏃ユ湡\", \"鎴愮珛鏃ユ湡\"])\n",
    "        industry = _first_value(cp, [\"鎵€灞炶涓歕", \"琛屼笟\"])\n",
    "        employees = _first_value(cp, [\"鍛樺伐浜烘暟\", \"闆囧憳浜烘暟\", \"鍛樺伐鎬绘暟\"])\n",
    "        intro = _first_value(cp, [\"鍏徃浠嬬粛\", \"鍏徃绠€浠媆", \"浠嬬粛\", \"绠€浠媆"])\n",
    "\n",
    "        sh = _as_bool(_first_value(sp, [\"鏄惁娌腐閫氭爣鐨刓", \"娌腐閫氭爣鐨刓", \"鏄惁娌腐閫歕"]))\n",
    "        sz = _as_bool(_first_value(sp, [\"鏄惁娣辨腐閫氭爣鐨刓", \"娣辨腐閫氭爣鐨刓", \"鏄惁娣辨腐閫歕"]))\n",
    "        hk_connect = None if (sh is None and sz is None) else bool(sh or sz)\n",
    "\n",
    "        mktcap = _first_value(fi, [\"鎬诲競鍊?娓厓)\", \"鎬诲競鍊糪", \"甯傚€?娓厓)\", \"甯傚€糪"])\n",
    "        div_yield = _first_value(fi, [\"鑲℃伅鐜嘥TM(%)\", \"鑲℃伅鐜嘥TM\", \"鑲℃伅鐜?%)\", \"鑲℃伅鐜嘰"])\n",
    "        pe = _first_value(fi, [\"甯傜泩鐜嘰", \"PE\", \"PE(TTM)\", \"甯傜泩鐜?TTM)\"])\n",
    "        pb = _first_value(fi, [\"甯傚噣鐜嘰", \"PB\", \"甯傚噣鐜?PB)\"])\n",
    "\n",
    "        rows.append(\n",
    "            {\n",
    "                \"ticker\": b.ticker,  # bundle閲岄€氬父宸叉槸 5浣?\"00001\"\n",
    "                \"鍚嶇О\": name,\n",
    "                \"娉ㄥ唽鍦癨": reg_place,\n",
    "                \"鎴愮珛鏃ユ湡\": founded,\n",
    "                \"琛屼笟\": industry,\n",
    "                \"鍛樺伐浜烘暟\": employees,\n",
    "                \"鍏徃浠嬬粛\": intro,\n",
    "                \"娓偂閫歕": hk_connect,  # 娌腐閫?娣辨腐閫?OR 鍚庣殑涓€鍒梊n",
    "                \"甯傚€?娓厓)\": mktcap,\n",
    "                \"鑲℃伅鐜嘥TM(%)\": div_yield,\n",
    "                \"PE\": pe,\n",
    "                \"PB\": pb,\n",
    "            }\n",
    "        )\n",
    "\n",
    "    df = pd.DataFrame(rows)\n",
    "\n",
    "    # 鍙€夛細鎶婃暟鍊煎垪杞垚 numeric锛堝け璐ュ垯淇濇寔鍘熸牱锛塡n",
    "    for col in [\"鍛樺伐浜烘暟\", \"甯傚€?娓厓)\", \"鑲℃伅鐜嘥TM(%)\", \"PE\", \"PB\"]:\n",
    "        if col in df.columns:\n",
    "            df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n",
    "\n",
    "    if \"ticker\" in df.columns:\n",
    "        df = df.sort_values(\"ticker\").reset_index(drop=True)\n",
    "\n",
    "    return df"
   ],
