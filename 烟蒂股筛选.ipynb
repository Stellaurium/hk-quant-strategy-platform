   "source": [
    "---\n",
    "\n",
    "### 鍒嗘瀽鑲＄エ鍒ゅ埆鍒楄〃鐨勫樊寮俓n",
    "\n",
    "鍒嗘瀽鎴戣繖閲岃幏寰楃殑鑲＄エ鍒楄〃(鏄庣‘鏄偂鏈被鍨? 鏈夎储鎶?璧勪骇璐熷€鸿〃涔嬬被鐨?\n",
    "鍜?浠庨娓氦鏄撴墍鎷垮埌鐨勫畼鏂圭殑琛ㄦ牸涔嬮棿鐨勫樊寮俓n",
    "\n",
    "宸紓宸茬粡鍐欏埌涓嬮潰鐨勫湴鏂逛簡 E:\\Program\\Python\\stock\\data\\stock_data\\globals\\stock_ticker_diff.txt\n"
   ],
   "id": "7942bbe95e6e6f18"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-02-23T06:52:22.392785Z",
     "start_time": "2026-02-23T06:52:22.300673Z"
    }
   },
   "cell_type": "code",
   "source": [
    "# 鍒嗘瀽\n",
    "# -----------------------------\n",
    "# 0) 閰嶇疆锛欻KEX 鍒楄〃 CSV 璺緞\n",
    "# -----------------------------\n",
    "hkex_csv = r\"E:\\Program\\Python\\stock\\data\\stock_data\\globals\\ListOfSecurities_c.csv\""
   ],
   "id": "747feb4bd3a1d47f",
   "outputs": [],
   "execution_count": 9
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-02-23T06:52:22.486614Z",
     "start_time": "2026-02-23T06:52:22.393784Z"
    }
   },
   "cell_type": "code",
   "source": [
    "\n",
    "# -----------------------------\n",
    "# 1) 瑙勮寖鍖栧伐鍏穃n",
    "# -----------------------------\n",
    "def norm_ticker(x) -> str:\n",
    "    if pd.isna(x):\n",
    "        return \"\"\n",
    "    s = str(x).strip().replace(\"\\u3000\", \"\").replace(\"\\xa0\", \"\")\n",
    "    return s.zfill(5) if s.isdigit() else s\n",
    "\n",
    "\n",
    "def norm_name(x) -> str:\n",
    "    if pd.isna(x):\n",
    "        return \"\"\n",
    "    s = str(x).strip().replace(\"\\u3000\", \" \").replace(\"\\xa0\", \" \")\n",
    "    return \" \".join(s.split())\n",
    "\n",
    "\n",
    "def build_pairs_from_df_spot(df_spot: pd.DataFrame, *, only_equity: bool = True) -> pd.DataFrame:\n",
    "    df = df_spot.copy()\n",
    "\n",
    "    if only_equity:\n",
    "        # is_equity 鍙兘鏄?boolean dtype锛屽惈 <NA>锛涜繖閲屾妸 NA 褰?False\n",
    "        df = df[df[\"is_equity\"].fillna(False)]\n",
    "\n",
    "    df[\"ticker\"] = df[\"浠ｇ爜\"].map(norm_ticker)\n",
    "    df[\"name\"] = df[\"鍚嶇О\"].map(norm_name)\n",
    "\n",
    "    df = df[df[\"ticker\"] != \"\"]\n",
    "    # 鍚屼竴 ticker 鍦?spot 閲岄€氬父涓嶄細閲嶅锛屼絾绋冲Ε璧疯鍘婚噸\n",
    "    return df[[\"ticker\", \"name\"]].drop_duplicates(\"ticker\", keep=\"first\")\n",
    "\n",
    "\n",
    "def load_hkex_pairs(csv_path: str) -> pd.DataFrame:\n",
    "    df = pd.read_csv(csv_path, encoding=\"utf-8-sig\", dtype={\"鑲′唤浠ｈ櫉\": str})\n",
    "    df[\"ticker\"] = df[\"鑲′唤浠ｈ櫉\"].map(norm_ticker)\n",
    "    df[\"name\"] = df[\"鑲′唤鍚嶇ū\"].map(norm_name)\n",
    "    df = df[df[\"ticker\"] != \"\"]\n",
    "    return df[[\"ticker\", \"name\"]].drop_duplicates(\"ticker\", keep=\"first\")"
   ],
   "id": "c37972831eb48840",
   "outputs": [],
   "execution_count": 10
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-02-23T06:52:22.621599Z",
     "start_time": "2026-02-23T06:52:22.487612Z"
    }
   },
   "cell_type": "code",
   "source": [
    "\n",
    "# -----------------------------\n",
    "# 2) 鏋勯€犱袱涓?(ticker, name) 琛╘n",
    "# -----------------------------\n",
    "pairs_spot_equity = build_pairs_from_df_spot(df_spot, only_equity=True)\n",
    "pairs_hkex = load_hkex_pairs(hkex_csv)"
   ],
   "id": "524a9c04ed6995eb",
   "outputs": [],
   "execution_count": 11
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-02-23T06:52:22.726438Z",
     "start_time": "2026-02-23T06:52:22.622598Z"
    }
   },
   "cell_type": "code",
   "source": [
    "# -----------------------------\n",
    "# 3) ticker 宸泦\n",
    "# -----------------------------\n",
    "set_spot = set(pairs_spot_equity[\"ticker\"])\n",
    "set_hkex = set(pairs_hkex[\"ticker\"])\n",
    "\n",
    "only_in_spot = sorted(set_spot - set_hkex)\n",
    "only_in_hkex = sorted(set_hkex - set_spot)\n",
    "in_both = sorted(set_spot & set_hkex)\n",
    "\n",
    "print(f\"spot(is_equity=True) tickers: {len(set_spot)}\")\n",
    "print(f\"HKEX tickers              : {len(set_hkex)}\")\n",
    "print(f\"Only in spot              : {len(only_in_spot)}\")\n",
    "print(f\"Only in HKEX              : {len(only_in_hkex)}\")\n",
    "print(f\"In both                   : {len(in_both)}\")\n",
    "\n",
    "# 鍙湪 spot 鐨勶細甯﹀悕绉癨n",
    "only_in_spot_df = pairs_spot_equity[pairs_spot_equity[\"ticker\"].isin(only_in_spot)].sort_values(\"ticker\")\n",
    "only_in_hkex_df = pairs_hkex[pairs_hkex[\"ticker\"].isin(only_in_hkex)].sort_values(\"ticker\")\n",
