   "cell_type": "code",
   "source": [
    "def screen_bs_mos(\n",
    "    df: pd.DataFrame,\n",
    "    *,\n",
    "    cap_min: float = 1e8,                      # 甯傚€间笅闄愶細50浜挎腐鍏僜n",
    "    mos_min: float = -0.5,                      # MOS_NormalAsset_minus_PriorityLiab 涓嬮檺\n",
    "    require_hk_connect: bool = False,           # 娓偂閫歕n",
    "    min_asset_to_debt: float = 0.4,            \n",
    ") -> pd.DataFrame:\n",
    "\n",
    "    d = df.copy()\n",
    "\n",
    "    # 1) 鏁版嵁璐ㄩ噺闂搁棬\n",
    "    mask = (d[\"ok\"] == True) & (d[\"skipped\"] == False) & (d[\"error\"].isna())\n",
    "\n",
    "    # 2) 甯傚€间笅闄怽n",
    "    mask &= d[\"甯傚€?娓厓)\"].notna() & (d[\"甯傚€?娓厓)\"] >= cap_min)\n",
    "\n",
    "    # 3) MOS 涓嬮檺\n",
    "    mask &= d[\"MOS_NormalAsset_minus_PriorityLiab\"].notna() & (d[\"MOS_NormalAsset_minus_PriorityLiab\"] >= mos_min)\n",
    "\n",
    "    # 4) 娓偂閫歕n",
    "    if require_hk_connect and \"娓偂閫歕" in d.columns:\n",
    "        mask &= (d[\"娓偂閫歕"] == True)\n",
    "\n",
    "\n",
    "    mask &= d[\"甯傚€?娓厓)\"].notna() & (d[\"LR_NormalAsset_over_TotalLiab\"] >= min_asset_to_debt)\n",
    "\n",
    "    out = d.loc[mask].sort_values(\n",
    "        by=[\"MOS_NormalAsset_minus_PriorityLiab\", \"甯傚€?娓厓)\"],\n",
    "        ascending=[False, False]\n",
    "    ).reset_index(drop=True)\n",
    "    return out"
   ],
